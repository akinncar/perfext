{
  "name": "perfext",
  "version": "0.1.0",
  "private": true,
  "description": "Perfext — a tool to make perfect texts. Grammarly-style browser extension + landing page.",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "package:extension": "node scripts/package-extension.mjs",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  },
  "pnpm": {
    "overrides": {
      "vite": "^7.3.5",
      "@vitejs/plugin-react": "^5.2.0"
    }
  }
}
